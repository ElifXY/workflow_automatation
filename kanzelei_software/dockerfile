# ============================================================
# KANZLEI AI — DOCKERFILE (API + Portal)
# ============================================================
# Build:  docker build -t kanzlei-ai .
# Run:    docker run -p 8000:8000 --env-file .env kanzlei-ai
# ============================================================

FROM python:3.11-slim

# System-Dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    libmagic1 \
    && rm -rf /var/lib/apt/lists/*

# Arbeitsverzeichnis
WORKDIR /app

# Dependencies zuerst (für besseres Caching)
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# App-Code kopieren
COPY . .

# Verzeichnisse anlegen
RUN mkdir -p data/uploads data/backups data/dokumente \
    modules core

# Fallback, falls eine veraltete compose-Datei USE_POSTGRES_DATA nicht setzt (sonst Production + SQLite-Fehler).
ENV USE_POSTGRES_DATA=1

# Nicht-Root User (Sicherheit)
RUN useradd -m -u 1000 kanzlei && \
    chown -R kanzlei:kanzlei /app
USER kanzlei

# Health-Check (127.0.0.1: konsistent mit compose; start_period groß für ersten Cold-Start)
HEALTHCHECK --interval=15s --timeout=10s --start-period=120s --retries=10 \
    CMD curl -fsS http://127.0.0.1:8000/ready || exit 1

EXPOSE 8000 8001

# Standard: API starten
CMD ["uvicorn", "backend.application:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]