# ============================================================
# KANZLEI AI — UMGEBUNGSVARIABLEN
# Datei: .env.example → nach .env kopieren und befüllen
# WICHTIG: .env niemals in Git committen!
# ============================================================

# ── PFLICHT ───────────────────────────────────────────────────
# OpenAI Key — für KI-Assistent (platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-XXXX

# Anthropic Key — für Steuer-Autopilot, Belegscanner, Dokument-Scanner
ANTHROPIC_API_KEY=sk-ant-api03-XXXX

PORTAL_SECRET=mindestens-32-zeichen-zufallsstring
PORTAL_ADMIN_KEY=kanzlei-admin-2024

# ── EMAIL ─────────────────────────────────────────────────────
EMAIL_USER=kanzlei@gmail.com
EMAIL_PASS=app-passwort-hier
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_FROM=Steuerkanzlei Müller <kanzlei@gmail.com>

# ── SERVER ────────────────────────────────────────────────────
APP_ENV=development
API_PORT=8000
API_WORKERS=2
PORTAL_PORT=8001
PORTAL_BASE_URL=http://localhost:8001
PORTAL_TOKEN_STUNDEN=168
REACT_APP_API_URL=http://localhost:8000
DOMAIN=kanzlei-ai.de
SSL_EMAIL=admin@kanzlei.de

# ── CORS (Frontend-URLs, kommagetrennt; kein "*" wenn Cookies genutzt werden) ─
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── DATENBANK ─────────────────────────────────────────────────
DATA_DIR=./data
# Docker mit Passwort: redis://:DEIN_REDIS_PASSWORT@redis:6379/0
# Lokal ohne Passwort: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=kanzlei-redis-2024
# PostgreSQL (optional, für >50 Mandanten):
# DATABASE_URL=postgresql://kanzlei:passwort@localhost:5432/kanzlei_ai
POSTGRES_USER=kanzlei
POSTGRES_PASSWORD=kanzlei_passwort
POSTGRES_DB=kanzlei_ai

# ── SICHERHEIT ────────────────────────────────────────────────
JWT_SECRET=langer-geheimer-string-mindestens-64-zeichen
SESSION_TIMEOUT_MINUTEN=60
IP_WHITELIST=
LOG_LEVEL=INFO
SENTRY_DSN=
ENVIRONMENT=development
FORCE_HTTPS=0
SECURITY_HEADERS=1

# ── BILLING ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_XXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXX

# ── BANK-SCHNITTSTELLEN ───────────────────────────────────────
FINTS_USER_ID=
FINTS_PIN=
FINTS_BLZ=
EBICS_HOST_URL=

# ── DRITTSYSTEME ──────────────────────────────────────────────
DATEV_CLIENT_ID=
DATEV_CLIENT_SECRET=
SHOPIFY_API_KEY=
SHOPIFY_STORE_URL=
AMAZON_ACCESS_KEY=
AMAZON_SELLER_ID=
PERSONIO_CLIENT_ID=
LEXOFFICE_API_KEY=

# ── ELSTER ────────────────────────────────────────────────────
ELSTER_ZERTIFIKAT_PFAD=
ELSTER_ZERTIFIKAT_PASSWORT=
ELSTER_BERATER_NR=

# ── PERFORMANCE & CRON ────────────────────────────────────────
STUNDENSATZ=150
KI_MAX_TOKENS=2048
KI_TIMEOUT_SEKUNDEN=60
PORTAL_UPLOAD_MAX_MB=20
API_RATE_LIMIT=60
BOT_ANALYSE_UHRZEIT=07:00
WORKFLOW_BATCH_UHRZEIT=06:00
BACKUP_UHRZEIT=02:00

# ── SAAS (Admin-API /saas/* — Header X-Saas-Master-Key) ───────
SAAS_MASTER_KEY=saas-master-admin-key-hier-eintragen

# ============================================================
# SCHNELL-START: Nur 3 Keys für minimalen Betrieb:
#   ANTHROPIC_API_KEY + PORTAL_SECRET + EMAIL_USER/PASS
# ============================================================
