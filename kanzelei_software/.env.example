# ============================================================
# KANZLEI AI — UMGEBUNGSVARIABLEN
# Datei: .env.example → nach .env kopieren und befüllen
# WICHTIG: .env niemals in Git committen!
# Docker Compose lädt zusätzlich .env.defaults (eingecheckt, nur Dev) und optional .env (Compose 2.24+).
# ============================================================

# ── PFLICHT ───────────────────────────────────────────────────
# OpenAI Key — für KI-Assistent (platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-XXXX

# Anthropic Key — für Steuer-Autopilot, Belegscanner, Dokument-Scanner
ANTHROPIC_API_KEY=sk-ant-api03-XXXX

PORTAL_SECRET=mindestens-32-zeichen-zufallsstring
PORTAL_ADMIN_KEY=kanzlei-admin-2024

# ── EMAIL ─────────────────────────────────────────────────────
EMAIL_USER=kanzlei@gmail.com
EMAIL_PASS=app-passwort-hier
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_FROM=Steuerkanzlei Müller <kanzlei@gmail.com>

# ── SERVER ────────────────────────────────────────────────────
APP_ENV=development
API_PORT=8000
API_PUBLIC_PORT=8000
API_WORKERS=2
# Portal läuft auf derselben App wie die API (Nginx /portal → api:8000).
PORTAL_PORT=8000
# Öffentliche Basis-URL der App (Einladungs-E-Mails: …/register-email?invite_token=…)
PORTAL_BASE_URL=http://localhost:8000
PORTAL_TOKEN_STUNDEN=168
REACT_APP_API_URL=http://localhost:8000
DOMAIN=kanzlei-automation.com
SSL_EMAIL=admin@kanzlei-automation.com

# Kundenzufriedenheit / Umsatz (optional): in 402 Plan-Limit und /billing/usage verlinkt
# BILLING_UPGRADE_URL=https://kanzlei-automation.com/plans
# SALES_CONTACT_URL=https://kanzlei-automation.com/kontakt
# SUPPORT_EMAIL=support@kanzlei-automation.com

# Stripe (optional): Checkout + Webhooks → POST /billing/stripe/webhook im Dashboard hinterlegen
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Price-IDs aus Produkt → Preise (wiederkehrend), passend zu professional / enterprise
# STRIPE_PRICE_ID_PROFESSIONAL=price_...
# STRIPE_PRICE_ID_ENTERPRISE=price_...
# STRIPE_API_VERSION=2023-10-16

# Bei ENVIRONMENT=production: API startet nur mit starkem JWT_SECRET, API_GATEWAY_KEY (≥32) und ohne Dev-Passwort in DATABASE_URL/REDIS_URL.
# Optional in Dev: leer lassen. In Prod: setzen — Zugriff nur mit Login-Session (Bearer) oder Header X-Api-Gateway-Key
# API_GATEWAY_KEY=
# Eigenes Secret fürs Mandantenportal (optional; sonst API_GATEWAY_KEY)
# PORTAL_GATEWAY_KEY=

# Docker (eingechecktes docker-compose.yml): setzt USE_POSTGRES_DATA=1 und DATABASE_URL für api/scheduler.
# In der Server-.env niemals USE_POSTGRES_DATA=0 setzen, sonst ENVIRONMENT=production + SQLite-Fehler.
# Umgebung prüfen: sh scripts/docker_api_diag.sh
# Docker Compose setzt DATABASE_URL/REDIS_URL automatisch — lokal ggf. manuell setzen.
# Nginx: production | development. TLS: Let’s Encrypt (DOMAIN) + lokal https://localhost (curl -k, Zertifikat im Image).
#   Renew-Reload: nginx/nginx-cert-watcher.sh → /var/log/nginx/cert-watcher.log
NGINX_ENV=production
# Hinter Cloudflare-Proxy: echte Client-IP + X-Forwarded-Proto (Nginx)
# CLOUDFLARE_PROXY=0
# HTTP 521: Cloudflare erreicht den Origin nicht — DNS A/AAAA auf Server-IP, Ports 80/443 offen,
#   Firewall, docker ps (api/nginx healthy), SSL-Modus „Full (strict)“ nur mit gültigem Origin-Zertifikat.
# Lokal: nach „docker compose up“ → curl -k https://localhost/ liefert die React-SPA (selbstsigniert im Nginx-Image).
# Docker-Frontend-Build: Standard /api (gleicher Host, HTTP-Bootstrap + HTTPS). Optional überschreiben.
# REACT_APP_API_URL=/api

# ── CORS (kommagetrennt; kein „*“ wenn Cookies genutzt werden) ─
# Ohne ALLOWED_ORIGINS: localhost + DOMAIN (https/http) werden in api.py ergänzt.
# ALLOWED_ORIGINS=https://kanzlei-automation.com,https://www.kanzlei-automation.com,http://localhost:3000
# Mandantenportal (optional, sonst wie ALLOWED_ORIGINS / DOMAIN-Default in portal_api.py)
# PORTAL_ALLOWED_ORIGINS=https://kanzlei-automation.com,https://www.kanzlei-automation.com
# Streng (nur wenn ENVIRONMENT=production): eine Origin — z. B. nur https://kanzlei-automation.com
# CORS_STRICT_PRODUCTION=0
# CORS_PRIMARY_ORIGIN=https://kanzlei-automation.com

# ── DATENBANK ─────────────────────────────────────────────────
# SQLite (Default): USE_POSTGRES_DATA=0 — data/kanzlei.db
# USE_POSTGRES_DATA=1 + DATABASE_URL=postgresql://…: Mandanten, Aufgaben, Audit, Einstellungen (inkl. compat::*), Portal-Records auf Postgres.
#   Hybrid: viele Domänen (Belege, Rechnungen, …) weiterhin SQLite (data/kanzlei.db), bis vollständig migriert.
#   Ist DATABASE_URL=postgresql://… gesetzt: core.auth (Benutzer), TenantManager (kanzleien),
#   USE_POSTGRES_DATA-Mandanten und SaaS-Hilfstabellen (api_keys, webhooks, email_outbox, usage_metrics, agent_actions)
#   nutzen dieselbe Thread-PG-Verbindung (core.pg_runtime).
# PG-Migration: scripts/migrate_sqlite_to_postgres.py
# USE_POSTGRES_DATA=0
# Wenn alle Domänen nur noch PostgreSQL nutzen sollen (experimentell): POSTGRES_ONLY_DATA=1 → SQLite get_connection deaktiviert.
# POSTGRES_ONLY_DATA=0
# Production + DATABASE_URL=postgresql://…: SQLite über get_connection standardmäßig aus (ohne Hybrid-Fallback).
# Übergang bis alle Tabellen auf PG: ALLOW_SQLITE_FALLBACK=1
# ALLOW_SQLITE_FALLBACK=0
DATA_DIR=./data
# Lokal ohne Redis-Passwort:
REDIS_URL=redis://localhost:6379/0
# Docker: Compose überschreibt mit redis://:${REDIS_PASSWORD}@redis:6379/0 — Passwort Pflicht.
REDIS_PASSWORD=VeryStrongRedis_ChangeMe_2026!
POSTGRES_USER=kanzlei
# Docker Compose: ohne .env nutzt Stack .env.defaults (Dev-Passwort enthält Präfix KzDevOnly_ — in Production ersetzen).
# Beispiel starkes Passwort (nur Format):
POSTGRES_PASSWORD=VeryStrongPassword_ChangeMe_2026!
# Achtung Docker: Das Passwort gilt nur beim ERSTEN Start des Named Volumes „postgres_data“.
# Später .env ändern ohne Volume-Löschung → API meldet „password authentication failed“ (Rolle kanzlei).
# Fix: Passwort in .env auf den alten Wert zurücksetzen, oder in Postgres ALTER USER, oder Volume entfernen (Daten weg).
POSTGRES_DB=kanzlei_ai
# Optional: Intervall Sekunden zwischen Dumps (Profil „backup“), Aufbewahrung Tage
# POSTGRES_BACKUP_INTERVAL_SEC=86400
# POSTGRES_BACKUP_KEEP_DAYS=14

# ── SICHERHEIT ────────────────────────────────────────────────
JWT_SECRET=langer-geheimer-string-mindestens-64-zeichen
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Mit JWT_SECRET: Login-Antwort enthält zusätzlich access_token (Bearer); API akzeptiert Session- oder JWT-Token.
# E-Mail-Login (curl/SPA): POST /login oder POST /api/login mit JSON {"email","password"} — Benutzer braucht gesetztes benutzer.email.
# Enterprise-Auth: E-Mail-Verifizierung vor Login erzwingen (1=an, 0=aus)
# AUTH_REQUIRE_EMAIL_VERIFIED=1
# AUTH_REQUIRE_ADMIN_KEY_FOR_LEGACY_REGISTER=0
# Passwort-Reset Hardening (pro Zeitfenster; Standardfenster 3600s)
# PWRESET_RATE_WINDOW_SECONDS=3600
# PWRESET_FORGOT_LIMIT_IP=6
# PWRESET_FORGOT_LIMIT_EMAIL=3
# PWRESET_RESET_LIMIT_IP=20
# Public Signup für /register (Default an). Für Invite-only: ALLOW_PUBLIC_REGISTER=0 + PORTAL_ADMIN_KEY nutzen.
# ALLOW_PUBLIC_REGISTER=1
# Beispiel nur für lokale Tests (Production: starkes Secret!): JWT_SECRET=CHANGE_THIS_NOW_123
# Optionaler Setup-Wert nur für einmaligen Bootstrap-Admin (>=12 Zeichen), kein Default im Code:
# INITIAL_ADMIN_PASSWORD=
# Optional: separates Secret (≥32) für POST /api/tenant/invites — sonst JWT_SECRET oder PORTAL_SECRET.
# INVITE_TOKEN_SECRET=
SESSION_TIMEOUT_MINUTEN=60
IP_WHITELIST=
LOG_LEVEL=INFO
SENTRY_DSN=
ENVIRONMENT=development
# API-Request-JSON-Log (stdout): in Production standardmäßig an; abschalten mit STRUCTURED_ACCESS_LOG=0
# STRUCTURED_ACCESS_LOG=
FORCE_HTTPS=0
SECURITY_HEADERS=1
# Advanced Domains (mandanten/dokumente/aufgaben/ai/...) erst nach bestandenem Baseline-Gate aktivieren.
# Default sicher: aus.
ENABLE_ADVANCED_FEATURES=0
# Optionaler Notfall-/lokaler Bootstrap fuer Testumgebungen (nie in Production aktiv lassen).
SECURITY_BASELINE_BOOTSTRAP=0
# Max. Alter des Baseline-Artefakts in Stunden fuer Feature-Freigabe.
SECURITY_BASELINE_MAX_AGE_HOURS=24

# ── BILLING ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_XXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXX

# ── BANK-SCHNITTSTELLEN ───────────────────────────────────────
FINTS_USER_ID=
FINTS_PIN=
FINTS_BLZ=
EBICS_HOST_URL=

# ── DRITTSYSTEME ──────────────────────────────────────────────
DATEV_CLIENT_ID=
DATEV_CLIENT_SECRET=
SHOPIFY_API_KEY=
SHOPIFY_STORE_URL=
AMAZON_ACCESS_KEY=
AMAZON_SELLER_ID=
PERSONIO_CLIENT_ID=
LEXOFFICE_API_KEY=

# ── ELSTER ────────────────────────────────────────────────────
ELSTER_ZERTIFIKAT_PFAD=
ELSTER_ZERTIFIKAT_PASSWORT=
ELSTER_BERATER_NR=

# ── PERFORMANCE & CRON ────────────────────────────────────────
STUNDENSATZ=150
KI_MAX_TOKENS=2048
KI_TIMEOUT_SEKUNDEN=60
PORTAL_UPLOAD_MAX_MB=20
API_RATE_LIMIT=60
BOT_ANALYSE_UHRZEIT=07:00
WORKFLOW_BATCH_UHRZEIT=06:00
BACKUP_UHRZEIT=02:00
REVENUE_OPS_UHRZEIT=08:30
REVENUE_OPS_MIN_VIEWS_7D=15
REVENUE_OPS_MIN_VIEW_TO_PAID_PCT=3.0

# ── SAAS (Admin-API /saas/* — Header X-Saas-Master-Key) ───────
SAAS_MASTER_KEY=saas-master-admin-key-hier-eintragen

# ============================================================
# SCHNELL-START: Nur 3 Keys für minimalen Betrieb:
#   ANTHROPIC_API_KEY + PORTAL_SECRET + EMAIL_USER/PASS
# ============================================================

# ── OAUTH / SOCIAL LOGIN (optional, High-End) ─────────────────
# Redirect-URI muss exakt mit Provider-Konsole übereinstimmen.
# Standard-Callback (wenn REDIRECT_URI leer): <PUBLIC_APP_URL>/api/auth/oauth/<provider>/callback
#
# Google
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GOOGLE_REDIRECT_URI=
#
# Microsoft
# OAUTH_MICROSOFT_CLIENT_ID=
# OAUTH_MICROSOFT_CLIENT_SECRET=
# OAUTH_MICROSOFT_REDIRECT_URI=
#
# Apple (Hinweis: produktiv oft JWT-Client-Secret nötig; je nach Setup gesondert erzeugen)
# OAUTH_APPLE_CLIENT_ID=
# OAUTH_APPLE_CLIENT_SECRET=
# OAUTH_APPLE_REDIRECT_URI=
