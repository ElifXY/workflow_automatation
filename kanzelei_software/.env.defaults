# ============================================================
# Standard-Umgebung für Docker Compose (lokal / CI / docker compose config)
# Nicht für Produktion: eigene .env aus .env.example bauen und starke Passwörter setzen.
# Überschreiben: zusätzliche Datei .env (optional, siehe docker-compose.yml)
# ENVIRONMENT=production erzwingt strenge Secrets (API/Portal starten sonst nicht).
# ============================================================
ENVIRONMENT=development
# USE_POSTGRES_DATA nicht auf 0 setzen, wenn du docker-compose nutzt: compose setzt 1 (Mandanten auf Postgres).
# Ohne Docker/lokal nur SQLite: Variable weglassen oder 0 — siehe .env.example.
POSTGRES_USER=kanzlei
POSTGRES_PASSWORD=KzDevOnly_ChangeBeforeProd_x9mK2vQ8wN4pL7a1b2c3d4
POSTGRES_DB=kanzlei_ai
REDIS_PASSWORD=KzDevOnly_ChangeBeforeProd_x9mK2vQ8wN4pL7a1b2c3d4
JWT_SECRET=dev-jwt-secret-minimum-64-characters-long-placeholder-for-local-docker-compose-stack-only
PORTAL_SECRET=dev-portal-secret-32-char-min-placeholder-for-compose
PORTAL_ADMIN_KEY=dev-admin-key-change-in-prod
OPENAI_API_KEY=sk-not-set
ANTHROPIC_API_KEY=sk-not-set
SSL_EMAIL=admin@example.invalid
DOMAIN=kanzlei-automation.com
# CORS (Browser): Produktions-Domain explizit; siehe backend.application CORSMiddleware
ALLOWED_ORIGINS=https://kanzlei-automation.com,https://www.kanzlei-automation.com,http://localhost:3000,http://127.0.0.1:3000
NGINX_ENV=production
CLOUDFLARE_PROXY=0
# Optional: setzen + starkes Secret — dann nur noch mit Bearer (Login) oder Header X-Api-Gateway-Key
API_GATEWAY_KEY=
